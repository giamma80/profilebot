              { "id": "custom.width", "value": 280 },
              { "id": "custom.align", "value": "left" },
              { "id": "displayName", "value": "Task" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Succeeded" },
            "properties": [
              { "id": "displayName", "value": "Completed" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Failed" },
            "properties": [
              { "id": "displayName", "value": "Failed" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
