{
  "uid": "profilebot-celery",
  "title": "ProfileBot - Celery",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Celery up",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"celery\"}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Queue length",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "celery_queue_length{queue_name=\"celery\"}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Active tasks",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "celery_worker_tasks_active"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 6
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Task success rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(celery_task_succeeded_total[5m])"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 6
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Task failure rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(celery_task_failed_total[5m])"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Task runtime p95 (s)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_runtime_bucket[5m])) by (le))"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      }
    }
  ]
}
