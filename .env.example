# ProfileBot Environment Configuration

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Azure OpenAI (alternative)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=10

# Redis
REDIS_URL=redis://localhost:6379

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Logging
LOG_LEVEL=INFO

# LLM settings
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_BASE_URL=
LLM_API_KEY=
LLM_API_VERSION=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Skills Dictionary
SKILLS_DICTIONARY_PATH=data/skills_dictionary.yaml

# Celery (Jobs: embedding + availability + scraper)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_RESULT_EXPIRES=86400
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=300

# Availability refresh (Celery Beat — via scraper service)
AVAILABILITY_REFRESH_SCHEDULE=0 * * * *
AVAILABILITY_CACHE_TTL=3600

# Reskilling
RESKILLING_CACHE_TTL=3600
RESKILLING_REFRESH_SCHEDULE=0 * * * *

# Scraper service
SCRAPER_BASE_URL=http://localhost:8001
SCRAPER_WORKFLOW_PATH=data/scraper_workflow.yaml
